                <UserObject label="" mermaidData="{&#10;  &quot;data&quot;: &quot;flowchart TD\n    subgraph \&quot;Camada de Interface &amp; Usuário\&quot;\n        U[Usuário] --&gt; ST[Streamlit Dashboard]\n        U --&gt; API[API REST FastAPI]\n        \n        ST --&gt;|interface web| PC1[Página: Overview &amp; EDA]\n        ST --&gt;|interface web| PC2[Página: Model Comparison]\n        ST --&gt;|interface web| PC3[Página: Agent Chat Interface]\n        ST --&gt;|interface web| PC4[Página: Property Insights]\n        ST --&gt;|interface web| PC5[Página: Market Analysis]\n        \n        API --&gt;|JSON responses| EX[External Systems]\n    end\n\n    subgraph \&quot;Camada de Orquestração\&quot;\n        AO[Agent Orchestrator] --&gt;|coordena| AM[Agent Manager]\n        AO --&gt;|gerencia| MM[Memory Manager]\n        AO --&gt;|armazena| CH[Chat History DB]\n        \n        AM --&gt;|registra| AR[Agent Registry]\n        MM --&gt;|vetoriza| VC[Vector Store&lt;br/&gt;ChromaDB/Pinecone]\n        MM --&gt;|contexto| CT[Context Manager]\n    end\n\n    subgraph \&quot;Camada de Agentes Especializados\&quot;\n        SA[Statistical Analyst Agent] --&gt;|analisa| EDA[Statistical Analysis]\n        VA[Valuation Specialist Agent] --&gt;|avalia| VAL[Price Valuation]\n        SE[Sales Engagement Agent] --&gt;|engaja| SALES[Sales Pitch]\n        MA[Market Analysis Agent] --&gt;|analisa| MARKET[Market Trends]\n        VIZ[Visualization Agent] --&gt;|gera| CHARTS[Interactive Charts]\n        \n        SA --&gt;|usa| STATS[StatsModels, SciPy]\n        VA --&gt;|usa| XAI[SHAP, LIME, PDP]\n        SE --&gt;|integra| LLM[LLM Service]\n        MA --&gt;|usa| TS[Time Series Analysis]\n        VIZ --&gt;|usa| PLOT[Plotly, Matplotlib]\n    end\n\n    subgraph \&quot;Camada de Serviços ML\&quot;\n        MS[Model Serving Layer] --&gt;|serve| MODELS[ML Models]\n        MS --&gt;|processa| FP[Feature Pipeline]\n        MS --&gt;|avalia| EVAL[Model Evaluator]\n        MS --&gt;|monitora| MON[Model Monitor]\n        \n        MODELS --&gt; LR[Linear Regression]\n        MODELS --&gt; RF[Random Forest]\n        MODELS --&gt; XGB[XGBoost]\n        MODELS --&gt; NN[Neural Network]\n        MODELS --&gt; ENS[Ensemble Model]\n        \n        FP --&gt;|engenharia| FE[Feature Engineering]\n        FP --&gt;|normalização| SC[Scaler]\n        FP --&gt;|seleção| FS[Feature Selector]\n    end\n\n    subgraph \&quot;Camada de Dados\&quot;\n        DS[Data Sources] --&gt;|carrega| DH[Data Handler]\n        \n        DH --&gt;|treinamento| TRAIN[Training Data]\n        DH --&gt;|produção| PROD[Production Data]\n        DH --&gt;|cache| CACHE[Feature Cache]\n        \n        TRAIN --&gt;|armazena| DB1[PostgreSQL/Parquet]\n        PROD --&gt;|armazena| DB2[Feature Store]\n        CACHE --&gt;|armazena| REDIS[Redis Cache]\n        \n        DB1 --&gt;|versiona| DVC[DVC Version Control]\n        DB2 --&gt;|sincroniza| FSYNC[Feature Sync]\n    end\n\n    subgraph \&quot;Camada de ML Ops\&quot;\n        TR[Training Pipeline] --&gt;|experimentos| MLF[MLflow Tracking]\n        TR --&gt;|versiona| MODREG[Model Registry]\n        TR --&gt;|automatiza| AUTOML[AutoML Pipeline]\n        \n        DEPLOY[Deployment] --&gt;|containeriza| DOCKER[Docker Container]\n        DEPLOY --&gt;|orquestra| K8S[Kubernetes]\n        DEPLOY --&gt;|escala| AUTO[Auto-scaling]\n        \n        MONITOR[Monitoring] --&gt;|logs| LOGS[Logging System]\n        MONITOR --&gt;|métricas| PROM[Prometheus]\n        MONITOR --&gt;|alertas| ALERTS[Alert Manager]\n    end\n\n    %% Conexões Principais\n    ST --&gt; AO\n    API --&gt; AO\n    \n    AO --&gt; SA\n    AO --&gt; VA\n    AO --&gt; SE\n    AO --&gt; MA\n    AO --&gt; VIZ\n    \n    SA --&gt; MS\n    VA --&gt; MS\n    SE --&gt; MS\n    MA --&gt; MS\n    \n    MS --&gt; DH\n    DH --&gt; DS\n    \n    TR --&gt; DH\n    TR --&gt; MS\n    \n    DEPLOY --&gt; MS\n    MONITOR --&gt; MS\n    \n    %% Fluxo de Dados Principal\n    DS --&gt;|California Housing Dataset| DH\n    DH --&gt;|processed data| FP\n    FP --&gt;|features| MODELS\n    MODELS --&gt;|predictions| MS\n    MS --&gt;|results| AO\n    AO --&gt;|insights + engagement| ST\n    \n    %% Fluxo de Agentes\n    U --&gt;|query/selection| ST\n    ST --&gt;|user context| AO\n    AO --&gt;|agent selection| AR\n    AR --&gt;|specialist agent| SA/VA/SE/MA/VIZ\n    SA/VA/SE/MA/VIZ --&gt;|analysis + recommendations| AO\n    AO --&gt;|formatted response| ST\n    ST --&gt;|display| U\n    \n    %% Conexões de Memória e Contexto\n    AO --&gt;|store context| MM\n    MM --&gt;|vector embeddings| VC\n    MM --&gt;|session data| CH\n    VC --&gt;|similarity search| AO\n    CH --&gt;|history retrieval| AO\n    \n    %% Model Management\n    MODELS --&gt;|register| MLF\n    MLF --&gt;|track experiments| TR\n    TR --&gt;|best model| MODREG\n    MODREG --&gt;|production model| DEPLOY\n    \n    %% Estilos\n    classDef userLayer fill:#e1f5fe,stroke:#01579b\n    classDef agentLayer fill:#f3e5f5,stroke:#4a148c\n    classDef mllayer fill:#e8f5e8,stroke:#1b5e20\n    classDef dataLayer fill:#fff3e0,stroke:#e65100\n    classDef opsLayer fill:#fce4ec,stroke:#880e4f\n    \n    class ST,API,PC1,PC2,PC3,PC4,PC5 userLayer\n    class AO,AM,MM,AR,SA,VA,SE,MA,VIZ agentLayer\n    class MS,MODELS,FP,EVAL,MON,LR,RF,XGB,NN,ENS mllayer\n    class DS,DH,TRAIN,PROD,CACHE,DB1,DB2,REDIS dataLayer\n    class TR,DEPLOY,MONITOR,MLF,MODREG,AUTOML opsLayer&quot;,&#10;  &quot;config&quot;: {&#10;    &quot;theme&quot;: &quot;neutral&quot;,&#10;    &quot;arrowMarkerAbsolute&quot;: false,&#10;    &quot;flowchart&quot;: {&#10;      &quot;htmlLabels&quot;: false&#10;    },&#10;    &quot;sequence&quot;: {&#10;      &quot;diagramMarginX&quot;: 50,&#10;      &quot;diagramMarginY&quot;: 10,&#10;      &quot;actorMargin&quot;: 50,&#10;      &quot;width&quot;: 150,&#10;      &quot;height&quot;: 65,&#10;      &quot;boxMargin&quot;: 10,&#10;      &quot;boxTextMargin&quot;: 5,&#10;      &quot;noteMargin&quot;: 10,&#10;      &quot;messageMargin&quot;: 35,&#10;      &quot;mirrorActors&quot;: true,&#10;      &quot;bottomMarginAdj&quot;: 1,&#10;      &quot;useMaxWidth&quot;: true,&#10;      &quot;rightAngles&quot;: false,&#10;      &quot;showSequenceNumbers&quot;: false&#10;    },&#10;    &quot;gantt&quot;: {&#10;      &quot;titleTopMargin&quot;: 25,&#10;      &quot;barHeight&quot;: 20,&#10;      &quot;barGap&quot;: 4,&#10;      &quot;topPadding&quot;: 50,&#10;      &quot;leftPadding&quot;: 75,&#10;      &quot;gridLineStartPadding&quot;: 35,&#10;      &quot;fontSize&quot;: 11,&#10;      &quot;fontFamily&quot;: &quot;\&quot;Open-Sans\&quot;, \&quot;sans-serif\&quot;&quot;,&#10;      &quot;numberSectionStyles&quot;: 4,&#10;      &quot;axisFormat&quot;: &quot;%Y-%m-%d&quot;&#10;    }&#10;  }&#10;}" id="2">
